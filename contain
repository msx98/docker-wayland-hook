#!/bin/bash

set -e

SCRIPT_PATH="$(realpath "$0")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
SPECS_DIR="${SCRIPT_DIR}/specs"

REBUILD=0
SHELL_MODE=0
UPDATE=0
DIRECT_DBUS=0
INSTANCE=""

while [[ "$1" == --* ]]; do
    case "$1" in
        --rebuild) REBUILD=1 ;;
        --build) REBUILD=1 ;;
        --shell)   SHELL_MODE=1 ;;
        --update)  UPDATE=1 ;;
        --setup)  UPDATE=1 ;;
        --dbus)    DIRECT_DBUS=1 ;;
        --name) shift; INSTANCE="$1" ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done
NAME="$1"
if [ "$INSTANCE" == "" ]; then
    INSTANCE="$NAME"
fi
echo "Executing $NAME ($INSTANCE)"

TMP_DIR=$(mktemp -d)
DBUS_PROXY_SOCK="$TMP_DIR/dbus.sock"
WAYLAND_PROXY_SOCK="$TMP_DIR/wayland.sock"
PULSE_PROXY_SOCK="$TMP_DIR/pulse.sock"
PIPEWIRE_PROXY_SOCK="$TMP_DIR/pipewire.sock"
KILL_PIDS=()
cleanup() {
    echo "Killing pids: ${KILL_PIDS[*]}"
    for pid in "${KILL_PIDS[@]}"; do
        if kill -0 "$pid" 2>/dev/null; then
            echo "Killing pid $pid..."
            kill -9 "$pid" 2>/dev/null || true
        fi
    done
    echo "Cleaning up proxy sockets..."
    # Look for any processes still using the proxy sockets and kill them
    for sock in "$DBUS_PROXY_SOCK" "$WAYLAND_PROXY_SOCK" "$PULSE_PROXY_SOCK" "$PIPEWIRE_PROXY_SOCK"; do
        if [ -S "$sock" ]; then
            echo "Checking for processes using $sock..."
            pids=$(lsof -t "$sock")
            if [ -n "$pids" ]; then
                echo "Killing processes using $sock: $pids"
                kill -9 $pids 2>/dev/null || true
            fi
        else
            echo "Socket $sock does not exist or is not a socket."
        fi
    done
    echo "Removing temporary directory $TMP_DIR..."
    rm -rf "$TMP_DIR"
    echo "Cleanup complete."
}


SPEC="$SPECS_DIR/$NAME"
IMAGE="localhost/contain:$NAME"
CONTAIN_ROOTFS="$HOME/.local/share/contain/$INSTANCE"
CONTAIN_HOME_GUEST="/home/user"
export CONTAIN_HOME_GUEST
CONTAIN_HOME="${CONTAIN_ROOTFS}/${CONTAIN_HOME_GUEST#"/"}"
DESKTOP_ENTRY_DIR=${DESKTOP_ENTRY_DIR:-"$HOME/.local/share/applications"}
UID_HOST=$(id -u)
UID_GUEST=${UID_GUEST:-1000}
XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$UID_HOST}
#XDG_RUNTIME_DIR_GUEST=${XDG_RUNTIME_DIR_GUEST:-"$XDG_RUNTIME_DIR_GUEST"}
XDG_RUNTIME_DIR_GUEST=${XDG_RUNTIME_DIR_GUEST:-"${CONTAIN_HOME_GUEST}/.xdg-runtime-dir"}
WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
WAYLAND_SOCK="${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}"


if [ ! -d "$SPEC" ]; then
    echo "Error: no spec found at $SPEC"
    exit 1
fi

trap cleanup EXIT

# Build image if it doesn't exist (or rebuild is forced)
if ! podman image exists "$IMAGE"; then
    echo "Image $IMAGE not found!"
    REBUILD=1
fi

if [ "$REBUILD" -eq 1 ]; then
    echo "Building image $IMAGE..."
    ./build "$NAME"
    UPDATE=1
fi

# Auto-export desktop entry if spec provides one
if [ -f "$SPEC/desktop" ]; then
    DEST="$DESKTOP_ENTRY_DIR/contain-$NAME-$INSTANCE.desktop"
    {
        cat "$SPEC/desktop"
        echo "Path=$SCRIPT_DIR"
        echo "Exec=contain --name $INSTANCE $NAME"
    } > "$DEST"
    if [ "$NAME" == "$INSTANCE" ]; then
        SUFFIX=" (Default)"
    else
        SUFFIX=" ($INSTANCE)"
    fi
    sed -i -E "s/Name=(.*)/Name=\1$SUFFIX/" "$DEST"
    update-desktop-database "$DESKTOP_ENTRY_DIR"
    echo "Installed desktop entry: $DEST"
fi

mkdir -p "$CONTAIN_HOME"
#mkdir -p "$CONTAIN_ROOTFS/runtime/dconf"
#chmod 777 "$CONTAIN_HOME"

# Load spec files
mapfile -t DBUS_NAMES   < "$SPEC/run.dbus"
mapfile -t PODMAN_EXTRA < <([ -f "$SPEC/run.podman" ] && grep -v '^#' "$SPEC/run.podman" || true)

readarray -t DBUS_NAMES < <(printf '%s\n' "${DBUS_NAMES[@]}" | grep -v '^$')
readarray -t PODMAN_EXTRA < <(printf '%s\n' "${PODMAN_EXTRA[@]}" | grep -v '^$' | envsubst)

# Get host GIDs
RENDER_GID=$(getent group render | cut -d: -f3)

# Start D-Bus proxy
if [ "$DIRECT_DBUS" -eq 1 ]; then
    DBUS_PROXY_SOCK="$XDG_RUNTIME_DIR_GUEST/bus"
else
    PROXY_ARGS=(--filter)
    for name in "${DBUS_NAMES[@]}"; do
        PROXY_ARGS+=("--talk=$name")
    done
    DBUS_NATIVE_PROXY_SOCK="$DBUS_PROXY_SOCK.native"
    xdg-dbus-proxy "$DBUS_SESSION_BUS_ADDRESS" "$DBUS_NATIVE_PROXY_SOCK" "${PROXY_ARGS[@]}" &
    KILL_PIDS+=($!)
    while [ ! -S "$DBUS_NATIVE_PROXY_SOCK" ]; do sleep 0.1; done
    #"$SCRIPT_DIR/proxy-socket" "$DBUS_PROXY_SOCK" "$DBUS_NATIVE_PROXY_SOCK" &
    #KILL_PIDS+=($!)
    DBUS_PROXY_SOCK="$DBUS_NATIVE_PROXY_SOCK"
fi

# Start socket proxies for Wayland, PulseAudio, and PipeWire.
# These let the container run as a different UID without needing setfacl
# on the real compositor/audio sockets.

"$SCRIPT_DIR/proxy-socket" "$WAYLAND_PROXY_SOCK"  "$WAYLAND_SOCK" &
KILL_PIDS+=($!)
"$SCRIPT_DIR/proxy-socket" "$PULSE_PROXY_SOCK"    "${XDG_RUNTIME_DIR}/pulse/native" &
KILL_PIDS+=($!)
"$SCRIPT_DIR/proxy-socket" "$PIPEWIRE_PROXY_SOCK" "${XDG_RUNTIME_DIR}/pipewire-0" &
KILL_PIDS+=($!)

for sock in "$DBUS_PROXY_SOCK" "$WAYLAND_PROXY_SOCK" "$PULSE_PROXY_SOCK" "$PIPEWIRE_PROXY_SOCK"; do
    while [ ! -S "$sock" ]; do sleep 0.05; done
done

PODMAN_RUN=("podman" "run")

# Flags shared between postbuild and normal run
COMMON_FLAGS=()
#COMMON_FLAGS+=("--name" "contain-$NAME")
#COMMON_FLAGS+=("--cap-drop" "ALL")
COMMON_FLAGS+=("--security-opt" "no-new-privileges")
COMMON_FLAGS+=("--security-opt" "label=type:container_runtime_t")
#COMMON_FLAGS+=("--cap-add" "ALL")
COMMON_FLAGS+=("--userns" "keep-id") #:uid=$UID_GUEST,gid=$UID_GUEST")
COMMON_FLAGS+=("--net" "pasta")
COMMON_FLAGS+=("--tmpfs" "$XDG_RUNTIME_DIR_GUEST:rw,mode=1777")
COMMON_FLAGS+=("-v" "$WAYLAND_PROXY_SOCK:$XDG_RUNTIME_DIR_GUEST/$WAYLAND_DISPLAY:ro")
COMMON_FLAGS+=("-v" "$PIPEWIRE_PROXY_SOCK:$XDG_RUNTIME_DIR_GUEST/pipewire-0:rw")
COMMON_FLAGS+=("-v" "$DBUS_PROXY_SOCK:$XDG_RUNTIME_DIR_GUEST/bus:rw")
COMMON_FLAGS+=("-v" "$PULSE_PROXY_SOCK:$XDG_RUNTIME_DIR_GUEST/pulse/native")
COMMON_FLAGS+=("-v" "$CONTAIN_HOME:$CONTAIN_HOME_GUEST:Z")
COMMON_FLAGS+=("-e" "HOME=$CONTAIN_HOME_GUEST")
COMMON_FLAGS+=("-e" "UID_GUEST=$UID_GUEST")
COMMON_FLAGS+=("-e" "GTK_THEME=Adwaita:dark")
COMMON_FLAGS+=("-e" "DBUS_SESSION_BUS_ADDRESS=unix:path=$XDG_RUNTIME_DIR_GUEST/bus")
COMMON_FLAGS+=("-e" "PULSE_SERVER=unix:$XDG_RUNTIME_DIR_GUEST/pulse/native")
COMMON_FLAGS+=("-e" "PIPEWIRE_REMOTE=$XDG_RUNTIME_DIR_GUEST/pipewire-0")
COMMON_FLAGS+=("-e" "XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR_GUEST")
COMMON_FLAGS+=("-e" "WAYLAND_DISPLAY=$WAYLAND_DISPLAY")
COMMON_FLAGS+=("-e" "XDG_SESSION_TYPE=wayland")
for extra in "${PODMAN_EXTRA[@]}"; do
echo "Adding extra podman flag: $extra"
    COMMON_FLAGS+=("$extra")
done
COMMON_FLAGS+=("$IMAGE")

echo "${PODMAN_RUN[@]}" -i --rm "${COMMON_FLAGS[@]}" dbus-run-session -- bash /init.sh

if [ "$UPDATE" -eq 1 ] && [ -f "$SPEC/setup.sh" ]; then
    echo "Running postbuild script for $NAME..."
    "${PODMAN_RUN[@]}" -it --rm \
        --user 0:0 \
        --cap-add ALL \
        -v "$(realpath "$SPEC/setup.sh"):/setup.sh:ro" \
        "${COMMON_FLAGS[@]}"  \
        dbus-run-session -- bash /setup.sh
fi

if [ "$UPDATE" -eq 1 ] && [ -f "$SPEC/setup.user.sh" ]; then
    echo "Running postbuild user script for $NAME..."
    "${PODMAN_RUN[@]}" -it --rm \
        -v "$(realpath "$SPEC/setup.user.sh"):/setup.sh:ro" \
        "${COMMON_FLAGS[@]}"  \
        dbus-run-session -- bash /setup.sh
fi

if [ -f "$SPEC/init.root.sh" ]; then
    echo "Running init script as root for $NAME..."
    "${PODMAN_RUN[@]}" -it --rm \
        --user 0:0 \
        --cap-add ALL \
        -v "$(realpath "$SPEC/init.root.sh"):/init.sh:ro" \
        "${COMMON_FLAGS[@]}"  \
        dbus-run-session -- bash /init.sh
fi

if [ "$SHELL_MODE" -eq 1 ]; then
    echo "Starting shell in container for $NAME..."
    "${PODMAN_RUN[@]}" -it --rm \
        "${COMMON_FLAGS[@]}" \
        dbus-run-session -- bash
else
    echo "Starting container for $NAME..."
    "${PODMAN_RUN[@]}" -i --rm \
        -v "$(realpath "$SPEC/init.sh"):/init.sh:ro" \
        --cap-drop ALL \
        "${COMMON_FLAGS[@]}" \
        dbus-run-session -- bash /init.sh
fi
