#!/bin/bash

set -e

REBUILD=0

while [[ "$1" == --* ]]; do
    case "$1" in
        --rebuild) REBUILD=1 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done

NAME="$1"
SPEC="./specs/$NAME"
IMAGE="localhost/contain:$NAME"
CONTAIN_HOME="$HOME/.local/share/contain/$NAME"
DESKTOP_ENTRY_DIR=${DESKTOP_ENTRY_DIR:-"$HOME/.local/share/applications"}
UID_HOST=$(id -u)
UID_GUEST=${UID_GUEST:-$UID_HOST}
XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$UID_HOST}
WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
WAYLAND_SOCK="${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}"


if [ ! -d "$SPEC" ]; then
    echo "Error: no spec found at $SPEC"
    exit 1
fi

# Build image if it doesn't exist (or rebuild is forced)
if [ "$REBUILD" -eq 1 ] || ! podman image exists "$IMAGE"; then
    [ "$REBUILD" -eq 1 ] && echo "Rebuilding image $IMAGE..." \
                         || echo "Image $IMAGE not found, building..."
    ./build "$NAME"
fi

# Auto-export desktop entry if spec provides one
if [ -f "$SPEC/desktop" ]; then
    DEST="$DESKTOP_ENTRY_DIR/contain-$NAME.desktop"
    LAUNCH_PATH="$(realpath "$0")"
    {
        cat "$SPEC/desktop"
        echo "Exec=$LAUNCH_PATH $NAME"
    } > "$DEST"
    update-desktop-database "$DESKTOP_ENTRY_DIR"
    echo "Installed desktop entry: $DEST"
fi

mkdir -p "$CONTAIN_HOME"
chmod 777 "$CONTAIN_HOME"

# Load spec files
mapfile -t CMD          < "$SPEC/run.args"
mapfile -t DBUS_NAMES   < "$SPEC/run.dbus"
mapfile -t PODMAN_EXTRA < <([ -f "$SPEC/run.podman" ] && grep -v '^#' "$SPEC/run.podman" || true)

# Strip blank lines
CMD=("${CMD[@]//[$'\n\r']/}")
CMD=("${CMD[@]}" )
readarray -t CMD < <(printf '%s\n' "${CMD[@]}" | grep -v '^$')
readarray -t DBUS_NAMES < <(printf '%s\n' "${DBUS_NAMES[@]}" | grep -v '^$')
readarray -t PODMAN_EXTRA < <(printf '%s\n' "${PODMAN_EXTRA[@]}" | grep -v '^$' | envsubst)

# Get host GIDs
RENDER_GID=$(getent group render | cut -d: -f3)

setfacl -m u:100999:rw "${WAYLAND_SOCK}"

# Start D-Bus proxy
DBUS_PROXY_SOCK="/tmp/dbus-proxy-$NAME"
PROXY_ARGS=(--filter)
for name in "${DBUS_NAMES[@]}"; do
    PROXY_ARGS+=("--talk=$name")
done
xdg-dbus-proxy "$DBUS_SESSION_BUS_ADDRESS" "$DBUS_PROXY_SOCK" "${PROXY_ARGS[@]}" &
DBUS_PROXY_PID=$!
trap "kill $DBUS_PROXY_PID 2>/dev/null; rm -f $DBUS_PROXY_SOCK" EXIT
while [ ! -S "$DBUS_PROXY_SOCK" ]; do sleep 0.1; done

echo "Running podman run"
podman run -i --rm \
  --security-opt label=type:container_runtime_t \
  --name "contain-$NAME" \
  --cap-drop ALL \
  --security-opt no-new-privileges \
  --group-add "$RENDER_GID" \
  --userns keep-id \
  --net pasta \
  -v "${WAYLAND_SOCK}":/run/user/$UID_GUEST/$WAYLAND_DISPLAY:ro \
  -v /run/user/$UID_GUEST/pipewire-0:/run/user/$UID_GUEST/pipewire-0:rw \
  -v "$DBUS_PROXY_SOCK":/run/user/$UID_GUEST/bus \
  -v "${XDG_RUNTIME_DIR}/pulse/native:/run/user/$UID_GUEST/pulse/native" \
  -v "$CONTAIN_HOME":/home/user:Z \
  -e GTK_THEME="Adwaita:dark" \
  -e DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$UID_GUEST/bus" \
  -e PULSE_SERVER=unix:/run/user/$UID_GUEST/pulse/native \
  -e PIPEWIRE_REMOTE=/run/user/$UID_GUEST/pipewire-0 \
  -e XDG_RUNTIME_DIR=/run/user/$UID_GUEST \
  -e WAYLAND_DISPLAY=$WAYLAND_DISPLAY \
  -e PIPEWIRE_REMOTE=unix:/run/user/$UID_GUEST/pipewire-0 \
  "${PODMAN_EXTRA[@]}" \
  $IMAGE \
  dbus-run-session -- "${CMD[@]}"
