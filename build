#!/bin/bash

set -e

if [ -z "$1" ]; then
    echo "Usage: ./build <base|app_name>"
    echo "  ./build ubuntu     - build base wayland-hook image"
    echo "  ./build chrome     - build wayland-hook:chrome from specs/chrome/install"
    exit 1
fi

NAME="$1"

# If a spec exists, build the app image
if [ -f "./specs/$NAME/Containerfile" ]; then
    echo "------------------------------------------"
    echo "Building wayland-hook:$NAME from specs/$NAME/Containerfile"
    echo "------------------------------------------"
    podman build -t "wayland-hook:$NAME" -f "./specs/$NAME/Containerfile" ./src
    echo "Build complete: wayland-hook:$NAME"
    exit 0
fi

# Otherwise treat as a base image name
BASE_FILE="src/dockerfiles/$NAME"
if [ ! -f "$BASE_FILE" ]; then
    echo "Error: no spec at specs/$NAME/Containerfile and no dockerfile at $BASE_FILE"
    exit 1
fi

echo "------------------------------------------"
echo "Building base image: wayland-hook from $BASE_FILE"
echo "------------------------------------------"
podman build -t wayland-hook -f "$BASE_FILE" ./src
echo "Build complete: wayland-hook"
