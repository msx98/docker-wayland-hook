ARG BASE
FROM $BASE

# 1. Install dependencies for the Google repo
RUN apt-get update && apt-get install -y \
    wget \
    gnupg \
    ca-certificates \
    --no-install-recommends

# 2. Add Google's signing key and repository
RUN wget -4 -q -O - https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor > /usr/share/keyrings/google-chrome.gpg && \
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list

# 3. Install Google Chrome and PipeWire client libs
RUN apt-get update && apt-get install -y \
    google-chrome-stable \
    --no-install-recommends && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# 4. Set Chrome-specific Wayland environment variables
# This tells Chrome to use the Wayland backend instead of X11
ENV CHROME_FLAGS="--ozone-platform-hint=auto --ozone-platform=wayland --gtk-version=4"

