FROM ubuntu:24.04

# Avoid prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# 1. Enable 'universe' repository for fonts and install core GUI dependencies
RUN apt-get update && apt-get install -y \
    software-properties-common && \
    add-apt-repository universe && \
    apt-get update && apt-get install -y \
    dbus-x11 \
    libwayland-client0 \
    libwayland-cursor0 \
    libwayland-egl1 \
    libgl1-mesa-dri \
    # In 24.04, libgles2-mesa is replaced by libgles2
    libgles2 \
    mesa-utils \
    # Hebrew Fonts
    fonts-noto-core \
    # Theme/Cursor fixes
    adwaita-icon-theme-full \
    fonts-dejavu \
    fontconfig \
    librsvg2-common \
    bash \
    libpipewire-0.3-0 \
    pipewire-audio-client-libraries \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# 2. Fix: Force GTK to find the Adwaita theme
RUN mkdir -p /usr/share/icons/default && \
    echo "[Icon Theme]" > /usr/share/icons/default/index.theme && \
    echo "Inherits=Adwaita" >> /usr/share/icons/default/index.theme

RUN apt-get update && apt-get install -y sudo

RUN mkdir -p /run/user/0 && chown root:root /run/user/0

RUN apt-get update && apt-get install -y \
    git \
    build-essential \
    --no-install-recommends && \
    git clone --depth 1 https://github.com/GrapheneOS/hardened_malloc.git /tmp/hardened_malloc && \
    make -C /tmp/hardened_malloc -j"$(nproc)" && \
    install -m 0755 /tmp/hardened_malloc/out/libhardened_malloc.so /usr/lib/libhardened_malloc.so && \
    printf '%s\n' /usr/lib/libhardened_malloc.so > /etc/ld.so.preload && \
    rm -rf /tmp/hardened_malloc && \
    apt-get purge -y git build-essential && \
    apt-get autoremove -y && \
    apt-get clean && rm -rf /var/lib/apt/lists/*


ARG UID=1000
ARG USER=user

RUN touch /var/mail/ubuntu && (userdel -r ubuntu || true) && \
    useradd -m -u $UID $USER && \
    mkdir -p /run/user/$UID && chown $USER:$USER /run/user/$UID && \
    echo "$USER ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
ENV MOZ_ENABLE_WAYLAND=1
ENV XCURSOR_THEME=Adwaita
ENV XCURSOR_SIZE=48
ENV GDK_BACKEND=wayland
ENV XCURSOR_PATH=/usr/share/icons

RUN fc-cache -f

COPY init.sh /

ENTRYPOINT ["bash", "/init.sh"]
